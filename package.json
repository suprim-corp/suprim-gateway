{
	"name": "kiro-gateway",
	"private": true,
	"packageManager": "bun@1.3.14",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"dev:api": "turbo dev --filter=@kiro-gateway/api",
		"dev:web": "turbo dev --filter=@kiro-gateway/web",
		"build": "turbo build",
		"test": "turbo test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"db:generate": "bun run --filter=@kiro-gateway/api db:generate",
		"db:migrate": "bun run --filter=@kiro-gateway/api db:migrate",
		"generate:key": "KEY=$(openssl rand -base64 32) && ([ -f .env ] && sed -i '' \"s|^ADMIN_API_KEY=.*|ADMIN_API_KEY=\\\"$KEY\\\"|\" .env || echo \"ADMIN_API_KEY=\\\"$KEY\\\"\" >> .env) && echo \"ADMIN_API_KEY=$KEY\""
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"turbo": "^2.3.0",
		"typescript": "^6.0.0"
	},
	"dependencies": {
		"cnfast": "^0.0.8"
	}
}
