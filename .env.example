# Kiro credentials (choose 1)
KIRO_CREDS_FILE="~/.aws/sso/cache/kiro-auth-token.json"
# REFRESH_TOKEN="your_refresh_token"
# KIRO_CLI_DB_FILE="~/.local/share/kiro-cli/data.sqlite3"

# Region
KIRO_REGION="us-east-1"
# KIRO_API_REGION=""

# Profile ARN (from kiro-cli state: api.codewhisperer.profile)
# PROFILE_ARN="arn:aws:codewhisperer:us-east-1:ACCOUNT:profile/ID"

# Admin dashboard
ADMIN_API_KEY="change-me-to-something-secure"

# Docker exposed port
# WEB_PORT=3000

# Database (for Docker, set to a persistent volume path)
# DATABASE_PATH="/app/data/gateway.db"

# Optional: VPN/Proxy
# VPN_PROXY_URL="http://127.0.0.1:7890"

# Optional: Debug
# LOG_LEVEL="info"
# DEBUG_MODE="off"

# Optional: Disable models (comma-separated)
# DISABLED_MODELS="claude-opus-4.5,claude-3.7-sonnet"

# Optional: Bind address (default 127.0.0.1, use 0.0.0.0 for container)
# HOST="127.0.0.1"
